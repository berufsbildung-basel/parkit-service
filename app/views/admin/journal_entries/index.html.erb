<% content_for :title, 'Journal Entries' %>

<section class="spectrum-CSSComponent-description">
  <h2 class="spectrum-Heading spectrum-Heading--sizeM">Journal Entries (Prepaid Users)</h2>
  <hr class="spectrum-Divider spectrum-Divider--large" style="margin-bottom: 1.5rem;">

  <div class="spectrum-Body spectrum-Body--sizeM">
    <table class="spectrum-Table spectrum-Table--sizeM">
      <thead class="spectrum-Table-head">
        <tr>
          <th class="spectrum-Table-headCell">User</th>
          <th class="spectrum-Table-headCell">Period</th>
          <th class="spectrum-Table-headCell">Amount</th>
          <th class="spectrum-Table-headCell">Reservations</th>
          <th class="spectrum-Table-headCell">Created</th>
        </tr>
      </thead>
      <tbody class="spectrum-Table-body">
        <% @journal_entries.each do |entry| %>
          <tr class="spectrum-Table-row">
            <td class="spectrum-Table-cell"><%= entry.user.email %></td>
            <td class="spectrum-Table-cell"><%= entry.period_start.strftime('%B %Y') %></td>
            <td class="spectrum-Table-cell"><%= number_to_currency(entry.total_amount, unit: 'CHF ') %></td>
            <td class="spectrum-Table-cell"><%= entry.reservation_count %></td>
            <td class="spectrum-Table-cell"><%= entry.created_at.strftime('%d.%m.%Y') %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <%= paginate @journal_entries if @journal_entries.respond_to?(:total_pages) %>

    <div style="margin-top: 1.5rem;">
      <%= link_to 'Back to Billing', admin_billing_path,
          class: 'spectrum-Button spectrum-Button--fill spectrum-Button--secondary spectrum-Button--sizeM' %>
    </div>
  </div>
</section>
