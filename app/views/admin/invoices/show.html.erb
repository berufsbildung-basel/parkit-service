<h1>Invoice Details</h1>

<p><%= link_to 'Back to Invoices', admin_invoices_path %></p>

<dl>
  <dt>User</dt>
  <dd><%= @invoice.user.email %></dd>

  <dt>Period</dt>
  <dd><%= @invoice.period_start.strftime('%B %Y') %></dd>

  <dt>Total Amount</dt>
  <dd><%= number_to_currency(@invoice.total_amount, unit: 'CHF ') %></dd>

  <dt>Status</dt>
  <dd><%= @invoice.status %></dd>

  <dt>Sent At</dt>
  <dd><%= @invoice.sent_at&.strftime('%d.%m.%Y %H:%M') || '-' %></dd>

  <dt>Paid At</dt>
  <dd><%= @invoice.paid_at&.strftime('%d.%m.%Y %H:%M') || '-' %></dd>

  <dt>CashCtrl Invoice ID</dt>
  <dd><%= @invoice.cashctrl_invoice_id || '-' %></dd>
</dl>

<h2>Line Items</h2>
<table>
  <thead>
    <tr>
      <th>Description</th>
      <th>Unit Price</th>
    </tr>
  </thead>
  <tbody>
    <% @invoice.line_items.each do |item| %>
      <tr>
        <td><%= item.description %></td>
        <td><%= number_to_currency(item.unit_price, unit: 'CHF ') %></td>
      </tr>
    <% end %>
  </tbody>
</table>
