# NOTE: This project uses Figaro for configuration.
# Copy config/application.yml.example to config/application.yml instead.
# This .env.example file is kept for reference only.
#
# CashCtrl Integration
# ====================
# Get your API key from CashCtrl: Settings > API Keys

# Your CashCtrl organization subdomain (e.g., "mycompany" from mycompany.cashctrl.com)
CASHCTRL_ORG=

# Your CashCtrl API key
CASHCTRL_API_KEY=

# Invoice category ID (determines numbering scheme and default accounts)
CASHCTRL_INVOICE_CATEGORY_ID=

# Sales account ID for invoice line items (e.g., 176 for parking revenue)
CASHCTRL_SALES_ACCOUNT_ID=

# Tax ID for invoice line items (e.g., 1 for MwSt 7.7%)
CASHCTRL_TAX_ID=

# Optional: The date when billing started (YYYY-MM-DD)
# Reservations before this date won't be billed
BILLING_START_DATE=

# Artikel numbers for parking reservations (not IDs!)
# Create these in CashCtrl: Inventory > Articles
CASHCTRL_ARTIKEL_CAR_HALFDAY_WEEKDAY=PARK-CAR-HD-WD
CASHCTRL_ARTIKEL_CAR_HALFDAY_WEEKEND=PARK-CAR-HD-WE
CASHCTRL_ARTIKEL_CAR_FULLDAY_WEEKDAY=PARK-CAR-FD-WD
CASHCTRL_ARTIKEL_CAR_FULLDAY_WEEKEND=PARK-CAR-FD-WE
CASHCTRL_ARTIKEL_MOTORCYCLE_HALFDAY_WEEKDAY=PARK-MC-HD-WD
CASHCTRL_ARTIKEL_MOTORCYCLE_HALFDAY_WEEKEND=PARK-MC-HD-WE
CASHCTRL_ARTIKEL_MOTORCYCLE_FULLDAY_WEEKDAY=PARK-MC-FD-WD
CASHCTRL_ARTIKEL_MOTORCYCLE_FULLDAY_WEEKEND=PARK-MC-FD-WE
